# AmanAI Environment Configuration
# Copy this file to .env and fill in values as needed.

# HuggingFace (required for gated models like Llama)
HF_TOKEN=your_hf_token_here

# LLM
# GPU model (requires CUDA) — used on Hydra cluster
LLM_MODEL_NAME=unsloth/Llama-3.2-3B-Instruct-bnb-4bit
# CPU fallback model (float32, no CUDA needed) — used on laptop
CPU_FALLBACK_MODEL=meta-llama/Llama-3.2-1B-Instruct
LLM_TEMPERATURE=0.1
LLM_MAX_NEW_TOKENS=512
# Path to fine-tuned LoRA adapter (set after running finetune.slurm)
LORA_ADAPTER_PATH=data/lora_adapter

# Embeddings
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DEVICE=cpu

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# Retrieval
CHROMA_COLLECTION_NAME=nust_bank_docs
BM25_WEIGHT=0.4
VECTOR_WEIGHT=0.6
RETRIEVAL_TOP_K=10
RERANK_TOP_K=5

# Guardrails
MAX_INPUT_LENGTH=1000
CHAT_HISTORY_TURNS=5
